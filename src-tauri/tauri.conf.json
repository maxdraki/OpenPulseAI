{
  "productName": "OpenPulse",
  "version": "0.1.0",
  "identifier": "com.openpulseai.desktop",
  "build": {
    "frontendDist": "../packages/ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm --filter @openpulse/ui dev:ui",
    "beforeBuildCommand": "pnpm --filter @openpulse/ui build"
  },
  "app": {
    "windows": [
      {
        "title": "OpenPulse",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "sidecars/openpulse-dream",
      "sidecars/openpulse-skills"
    ],
    "resources": {
      "../packages/skills/builtin/**/*": "builtin-skills/"
    }
  },
  "plugins": {
    "shell": {
      "open": false
    }
  }
}
